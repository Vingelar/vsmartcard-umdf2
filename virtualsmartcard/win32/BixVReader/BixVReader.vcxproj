  <!-- Test-signing configuration: self-signed cert auto-generated by EnsureTestCert.ps1 -->
  <PropertyGroup>
    <TestCertDir>$(MSBuildThisFileDirectory)..\TestCert</TestCertDir>
    <TestCertPfx>$(TestCertDir)\BixVReader.pfx</TestCertPfx>
    <!-- install_vpcd.bat expects the public cert next to itself -->
    <TestCertCer>$(MSBuildThisFileDirectory)..\BixVReader.cer</TestCertCer>
    <TestCertSubject>BixVReader Test Code Signing</TestCertSubject>
    <TestCertPassword>BixVReader!</TestCertPassword>
  </PropertyGroup>
  <Target Name="EnsureTestCert" BeforeTargets="ClCompile">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)..\EnsureTestCert.ps1&quot; -PfxPath &quot;$(TestCertPfx)&quot; -CerPath &quot;$(TestCertCer)&quot; -Subject &quot;$(TestCertSubject)&quot; -Password &quot;$(TestCertPassword)&quot;" />
  </Target>
  <!-- Auto passwordless test-signing for UMDF DLLs -->
  <Target Name="AutoTestSignUMDF" AfterTargets="Build">
    <PropertyGroup>
      <StampinfPath>&quot;$(WindowsSDK_DesktopBinPath)Stampinf.exe&quot;</StampinfPath>
      <Inf2CatPath>&quot;$(WindowsSDK_DesktopBinPath)inf2cat.exe&quot;</Inf2CatPath>
      <SignToolPath>&quot;$(WindowsSDK_DesktopBinPath)signtool.exe&quot;</SignToolPath>
      <Inf2CatOS>10_$(PlatformShortName),ServerRS5_$(PlatformShortName),ServerFE_$(PlatformShortName)</Inf2CatOS>
    </PropertyGroup>
    <Exec
      Command="$(SignToolPath) sign /fd SHA256 /f &quot;$(TestCertPfx)&quot; /p $(TestCertPassword) /v &quot;$(TargetPath)&quot;"
      />
    <Exec
      Command="$(StampinfPath) -f BixVReader.inf -d * -v 1.0.0.0 -a $(PlatformShortName)"
      WorkingDirectory="$(OutDir)"
      />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;Get-Content BixVReader.inf&quot;"
      WorkingDirectory="$(OutDir)"
      />
    <Exec
      Command="$(Inf2CatPath) /driver:. /os:$(Inf2CatOS) /verbose"
      WorkingDirectory="$(OutDir)"
      />
    <Exec Command="$(SignToolPath) sign /fd SHA256 /f &quot;$(TestCertPfx)&quot; /p $(TestCertPassword) /v bixvreader.cat"
      WorkingDirectory="$(OutDir)"
      />
  </Target>
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
